# Archon-DeerFlow Docker Environment
# Copy to .env and fill in your values

# Required: DeepSeek API key
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: Port (default: 8001 for gateway, 2026 for nginx)
PORT=8001
NGINX_PORT=2026

# Optional: Workspace path (mount point for Lean projects)
WORKSPACE_PATH=./workspace

# Optional: Enable SqliteSaver (Docker mode enables by default)
DEER_FLOW_DOCKER=1
CHECKPOINT_DB_PATH=/app/backend/data/checkpoints.db
