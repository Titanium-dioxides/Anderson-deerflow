# ── LangGraph Studio — graph visualization only ──
# Minimal image: no deer-flow Gateway, no frontend, no nginx.
# Only langgraph + our overlay workflows.
# ────────────────────────────────────────────────────────────

FROM python:3.12-slim-bookworm

# ── System deps ──
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# ── uv (for langgraph dev dependency resolution) ──
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# ── Python deps (only what langgraph dev needs) ──
RUN pip install "langgraph-cli[inmem]" langgraph langgraph-checkpoint langgraph-sdk \
    langchain langchain-core

# ── Our overlay ──
WORKDIR /app
COPY overlay ./overlay

# ── Studio workspace ──
COPY studio/pyproject.toml ./pyproject.toml
COPY studio/langgraph.json ./langgraph.json
COPY archon_graphs.py ./archon_graphs.py

ENV PYTHONPATH=/app/overlay/backend:/app:$PYTHONPATH
ENV LANG=C.UTF-8 LC_ALL=C.UTF-8 PYTHONIOENCODING=utf-8

EXPOSE 8123

ENTRYPOINT ["langgraph", "dev", "--port", "8123", "--host", "0.0.0.0", "--no-browser", "--config", "/app/langgraph.json"]
